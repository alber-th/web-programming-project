<header class="site-header">
  <div class="container">
    <a class="brand" href="/">Cloud Key</a>
    <nav class="nav">
      <a href="/">Home</a>
      <a href="/products">Produtos</a>
      <a href="/cart" class="nav-cart" aria-label="Carrinho">
        🛒 Carrinho
        <% if (typeof cartCount !== 'undefined' && cartCount > 0) { %>
          <span class="cart-badge"><%= cartCount %></span>
        <% } %>
      </a>
      <% if (currentUser) { %>
        <a href="/transactions"><%= currentUser.role === 'ADMIN' ? 'Transações' : 'Minhas Transações' %></a>
        <% if (currentUser.role === 'ADMIN') { %>
          <a href="/products/new">Novo Produto</a>
        <% } %>
        <span class="nav-user">Bem-vindo, <%= currentUser.name %></span>
        <form action="/logout" method="POST" class="nav-form">
          <button type="submit" class="link-button">Sair</button>
        </form>
      <% } else { %>
        <a href="/register">Registrar-se</a>
        <a href="/login">Entrar</a>
      <% } %>
    </nav>
  </div>
</header>
