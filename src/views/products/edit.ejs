<%- include('../partials/head') %>
<body>
  <%- include('../partials/header') %>

  <main class="container">
    <section class="form-card">
      <h1>Editar produto</h1>
      <%- include('../partials/flash') %>

      <form action="/products/<%= product.id %>?_method=PUT" method="POST" novalidate>
        <div class="field">
          <label for="name">Nome</label>
          <input
            type="text"
            id="name"
            name="name"
            value="<%= formData.name %>"
            required
          />
          <% if (errors.name) { %>
            <span class="field-error"><%= errors.name %></span>
          <% } %>
        </div>

        <div class="field">
          <label for="platform">Plataforma</label>
          <input
            type="text"
            id="platform"
            name="platform"
            value="<%= formData.platform %>"
            required
          />
          <% if (errors.platform) { %>
            <span class="field-error"><%= errors.platform %></span>
          <% } %>
        </div>

        <div class="field">
          <label for="category">Categoria</label>
          <input
            type="text"
            id="category"
            name="category"
            value="<%= formData.category || '' %>"
            placeholder="RPG, FPS, Aventura, etc."
          />
        </div>

        <div class="field">
          <label for="imageUrl">URL da imagem de capa</label>
          <input
            type="url"
            id="imageUrl"
            name="imageUrl"
            value="<%= formData.imageUrl || '' %>"
            placeholder="https://..."
          />
        </div>

        <div class="field">
          <label for="price">Preço (R$)</label>
          <input
            type="number"
            id="price"
            name="price"
            value="<%= formData.price %>"
            step="0.01"
            min="0.01"
            required
          />
          <% if (errors.price) { %>
            <span class="field-error"><%= errors.price %></span>
          <% } %>
        </div>

        <div class="field">
          <label for="stock">Estoque</label>
          <input
            type="number"
            id="stock"
            name="stock"
            value="<%= formData.stock %>"
            step="1"
            min="0"
          />
          <% if (errors.stock) { %>
            <span class="field-error"><%= errors.stock %></span>
          <% } %>
        </div>

        <button type="submit" class="btn-primary">Salvar alterações</button>
        <p class="form-footer"><a href="/products">Cancelar</a></p>
      </form>
    </section>
  </main>

  <%- include('../partials/footer') %>
