<%- include('../partials/head') %>
<body>
  <%- include('../partials/header') %>

  <main class="container">
    <section class="page">
      <div class="page-header">
        <h1>Produtos</h1>
        <% if (currentUser && currentUser.role === 'ADMIN') { %>
          <a href="/products/new" class="btn-primary inline">+ Novo produto</a>
        <% } %>
      </div>

      <%- include('../partials/flash') %>

      <% if (products.length === 0) { %>
        <p class="muted">Nenhum produto cadastrado ainda.</p>
      <% } else { %>
        <table class="data-table">
          <thead>
            <tr>
              <th>Nome</th>
              <th>Plataforma</th>
              <th>Preço</th>
              <th>Estoque</th>
              <% if (currentUser) { %>
                <th>Ações</th>
              <% } %>
            </tr>
          </thead>
          <tbody>
            <% products.forEach(function (product) { %>
              <tr>
                <td><%= product.name %></td>
                <td><%= product.platform %></td>
                <td>R$ <%= Number(product.price).toFixed(2).replace('.', ',') %></td>
                <td><%= product.stock %></td>
                <% if (currentUser) { %>
                  <td>
                    <div class="actions">
                      <form class="inline-form" action="/transactions" method="POST">
                        <input type="hidden" name="productId" value="<%= product.id %>" />
                        <input type="hidden" name="quantity" value="1" />
                        <button type="submit" class="btn-buy">Comprar</button>
                      </form>
                      <% if (currentUser.role === 'ADMIN') { %>
                        <a class="btn-edit" href="/products/<%= product.id %>/edit">Editar</a>
                        <form
                          class="inline-form"
                          action="/products/<%= product.id %>?_method=DELETE"
                          method="POST"
                          onsubmit="return confirm('Tem certeza que deseja excluir este produto?');"
                        >
                          <button type="submit" class="btn-danger">Excluir</button>
                        </form>
                      <% } %>
                    </div>
                  </td>
                <% } %>
              </tr>
            <% }); %>
          </tbody>
        </table>
      <% } %>
    </section>
  </main>

  <%- include('../partials/footer') %>
